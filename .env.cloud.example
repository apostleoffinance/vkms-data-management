# =============================================================================
# VKMS Cloud Deployment (Neon + Render + Vercel)
# =============================================================================
# Do NOT commit real secrets. Set these in each platform's dashboard:
#   - Neon:     DATABASE_URL (from Neon console)
#   - Render:   backend env vars below
#   - Vercel:   NEXT_PUBLIC_API_URL
# =============================================================================

# --- Neon PostgreSQL ---
# Copy from Neon dashboard (Connection string). Must include SSL:
# DATABASE_URL=postgresql://user:pass@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# --- Render (backend) ---
JWT_SECRET_KEY=generate-with-openssl-rand-hex-32
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:3000,https://YOUR-APP.vercel.app
COOKIE_SECURE=true
COOKIE_SAMESITE=none
DEBUG=false
RATE_LIMIT=100/minute
DEFAULT_ADMIN_EMAIL=admin@votagekids.org
DEFAULT_ADMIN_PASSWORD=choose-a-strong-password

# --- Vercel (frontend) — set in Vercel project settings ---
# NEXT_PUBLIC_API_URL=https://YOUR-SERVICE.onrender.com
